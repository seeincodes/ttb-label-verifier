# Template environment file for the TTB Label Verification prototype.
# Copy this file to `.env` and fill in the secrets (GEMINI_API_KEY, OPENAI_API_KEY).
# `.env` is gitignored; `.env.example` is committed as the canonical config reference.
# Mirror any changes here in `.env` and in docs/TECH_STACK.md "Environment Variables".

# === Vision Model Configuration ===
# Active extractor: gemini (default) | openai
EXTRACTOR_PROVIDER=gemini

# Required if EXTRACTOR_PROVIDER=gemini OR the automatic fallback fires.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required if EXTRACTOR_PROVIDER=openai OR the automatic fallback fires.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# === Timeouts & Performance ===
# Per-extractor-call timeout in seconds. On timeout, the alternate provider is tried once.
EXTRACTION_TIMEOUT_SECONDS=8

# Max simultaneous extractions in the batch flow (asyncio.Semaphore).
BATCH_CONCURRENCY=5

# In-memory LRU cache size (entries). Key = sha256(image_bytes).
CACHE_MAXSIZE=128

# === Application ===
# development | production
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
# Render injects $PORT at runtime; uvicorn should bind to it in production.
PORT=8000
